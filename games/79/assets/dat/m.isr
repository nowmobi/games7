		</string>

		<string id="CRITICAL_TEXT" index="13">
			<en>INCREASES THE CHANCE TO CAUSE DOUBLE DAMAGE</en>
			<es>AUMENTA LA POSIBILIDAD DE CAUSAR DANO DOBLE</es>
			<de>ERHÖHT DIE CHANCE, DOPPELTE BESCHÄDIGUNG ZU VERURSACHEN</de>
