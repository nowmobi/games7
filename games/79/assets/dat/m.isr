		<string id="STRENGTH_TEXT" index="10">
			<en>INCREASES THE BASIC DAMAGE CAUSED AGAINST THE ENEMY</en>
			<es>AUMENTA EL DANO BÁSICO CAUSADO POR EL ENEMIGO</es>
			<de>ERHÖHT DIE GRUNDLEGENDE BESCHÄDIGUNG, VERURSACHT GEGEN DEN FEIND</de>
