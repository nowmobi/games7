			<ru>УВЕЛИЧИВАЕТ ШАНСЫ НА ЗАМЕДЛЕНИЕ ВРАГОВ </ru>
		</string>

		<string id="MAGE_TOWER_TEXT" index="15">
			<en>INCREASES THE AMOUNT OF THE MANNA AND UNLOCKS THE MAGIC</en>
